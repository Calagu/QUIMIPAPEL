<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qumi.app.controller.ProductosController">
    <padding>
        <Insets top="24" right="28" bottom="28" left="28"/>
    </padding>
    <top>
        <VBox spacing="12">
            <VBox spacing="5">
                <Label text="Gestión de productos" styleClass="page-title"/>
                <Label text="Alta, edición, baja, stock mínimo, buscador y exportación." styleClass="muted"/>
            </VBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Buscar por nombre, categoría o descripción" HBox.hgrow="ALWAYS" onAction="#refresh"/>
                <Button text="Buscar" onAction="#refresh" styleClass="secondary-button"/>
                <Button text="Exportar CSV" onAction="#exportCsv" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox spacing="18">
            <TableView fx:id="productosTable" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="55"/>
                    <TableColumn fx:id="nombreColumn" text="Producto" prefWidth="190"/>
                    <TableColumn fx:id="categoriaColumn" text="Categoría" prefWidth="120"/>
                    <TableColumn fx:id="precioColumn" text="Precio" prefWidth="85"/>
                    <TableColumn fx:id="stockColumn" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="stockEstadoColumn" text="Estado stock" prefWidth="105"/>
                    <TableColumn fx:id="activoColumn" text="Activo" prefWidth="70"/>
                </columns>
            </TableView>
            <VBox spacing="10" prefWidth="300" styleClass="form-card">
                <Label text="Ficha de producto" styleClass="section-title"/>
                <TextField fx:id="nombreField" promptText="Nombre"/>
                <TextField fx:id="categoriaField" promptText="Categoría"/>
                <TextArea fx:id="descripcionArea" promptText="Descripción" prefRowCount="3"/>
                <GridPane hgap="8" vgap="8">
                    <TextField fx:id="precioField" promptText="Precio" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="stockField" promptText="Stock" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="stockMinimoField" promptText="Stock mínimo" text="5" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <CheckBox fx:id="activoCheck" text="Activo" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
                <HBox spacing="8">
                    <Button text="Guardar" onAction="#save" styleClass="primary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Limpiar" onAction="#clear" styleClass="secondary-button"/>
                </HBox>
                <Button text="Eliminar" onAction="#delete" styleClass="danger-button" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
