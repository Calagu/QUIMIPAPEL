<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qumi.app.controller.ClientesController">
    <padding>
        <Insets top="24" right="28" bottom="28" left="28"/>
    </padding>
    <top>
        <VBox spacing="12">
            <VBox spacing="5">
                <Label text="Gestión de clientes" styleClass="page-title"/>
                <Label text="Registro de clientes, empresas, direcciones de entrega y zonas." styleClass="muted"/>
            </VBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Buscar por cliente, empresa, teléfono, email, zona o dirección" HBox.hgrow="ALWAYS" onAction="#refresh"/>
                <Button text="Buscar" onAction="#refresh" styleClass="secondary-button"/>
                <Button text="Exportar CSV" onAction="#exportCsv" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox spacing="18">
            <TableView fx:id="clientesTable" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="55"/>
                    <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="140"/>
                    <TableColumn fx:id="empresaColumn" text="Empresa" prefWidth="160"/>
                    <TableColumn fx:id="telefonoColumn" text="Teléfono" prefWidth="110"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="165"/>
                    <TableColumn fx:id="zonaColumn" text="Zona" prefWidth="90"/>
                    <TableColumn fx:id="activoColumn" text="Activo" prefWidth="70"/>
                </columns>
            </TableView>
            <VBox spacing="10" prefWidth="300" styleClass="form-card">
                <Label text="Ficha de cliente" styleClass="section-title"/>
                <TextField fx:id="nombreField" promptText="Nombre de contacto"/>
                <TextField fx:id="empresaField" promptText="Empresa"/>
                <TextField fx:id="telefonoField" promptText="Teléfono"/>
                <TextField fx:id="emailField" promptText="Email"/>
                <TextField fx:id="zonaField" promptText="Zona de reparto"/>
                <TextArea fx:id="direccionArea" promptText="Dirección completa" prefRowCount="3"/>
                <CheckBox fx:id="activoCheck" text="Cliente activo"/>
                <HBox spacing="8">
                    <Button text="Guardar" onAction="#save" styleClass="primary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Limpiar" onAction="#clear" styleClass="secondary-button"/>
                </HBox>
                <Button text="Eliminar" onAction="#delete" styleClass="danger-button" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
