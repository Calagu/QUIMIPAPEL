<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="login-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qumi.app.controller.LoginController">
    <left>
        <VBox alignment="CENTER_LEFT" spacing="18" prefWidth="520" styleClass="login-hero">
            <padding>
                <Insets top="70" right="60" bottom="70" left="70"/>
            </padding>
            <Label text="QUMI PAPEL" styleClass="brand-title"/>
            <Label text="Sistema digital para gestión de pedidos, clientes, productos y reparto." wrapText="true" styleClass="hero-text"/>
            <VBox spacing="8" styleClass="hero-list">
                <Label text="✓ Login por roles"/>
                <Label text="✓ Gestión de clientes y productos"/>
                <Label text="✓ Creación y consulta de pedidos"/>
                <Label text="✓ Cambio de estado y vista de reparto"/>
                <Label text="✓ Filtros, exportación e indicadores"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <HBox alignment="CENTER">
            <VBox alignment="CENTER_LEFT" spacing="14" maxWidth="360" styleClass="login-card">
                <Label text="Acceso al sistema" styleClass="section-title"/>
                <Label text="Introduce tus credenciales para continuar" styleClass="muted"/>
                <TextField fx:id="usernameField" promptText="Usuario" onAction="#login"/>
                <PasswordField fx:id="passwordField" promptText="Contraseña" onAction="#login"/>
                <Label fx:id="errorLabel" styleClass="error-label"/>
                <Button text="Entrar" maxWidth="Infinity" onAction="#login" styleClass="primary-button"/>
                <Region prefHeight="8"/>
                <VBox spacing="4" styleClass="credentials-box">
                    <Label text="Usuarios de prueba:" styleClass="mini-title"/>
                    <Label text="admin / admin123"/>
                    <Label text="comercial / comercial123"/>
                    <Label text="oficina / oficina123"/>
                    <Label text="reparto / reparto123"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
