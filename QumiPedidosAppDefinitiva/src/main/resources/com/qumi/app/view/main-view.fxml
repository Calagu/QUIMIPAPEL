<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qumi.app.controller.MainController">
    <left>
        <VBox prefWidth="245" spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="22" right="16" bottom="22" left="16"/>
            </padding>
            <Label text="QUMI" styleClass="sidebar-brand"/>
            <Label text="Pedidos y reparto" styleClass="sidebar-subtitle"/>
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Button fx:id="dashboardButton" text="Dashboard" maxWidth="Infinity" onAction="#showDashboard" styleClass="nav-button"/>
                <Button fx:id="clientesButton" text="Clientes" maxWidth="Infinity" onAction="#showClientes" styleClass="nav-button"/>
                <Button fx:id="productosButton" text="Productos" maxWidth="Infinity" onAction="#showProductos" styleClass="nav-button"/>
                <Button fx:id="pedidosButton" text="Pedidos" maxWidth="Infinity" onAction="#showPedidos" styleClass="nav-button"/>
                <Button fx:id="repartoButton" text="Vista de reparto" maxWidth="Infinity" onAction="#showReparto" styleClass="nav-button"/>
                <Button fx:id="usuariosButton" text="Usuarios" maxWidth="Infinity" onAction="#showUsuarios" styleClass="nav-button"/>
            </VBox>
            <VBox spacing="2" styleClass="user-box">
                <Label fx:id="userLabel" text="Usuario" styleClass="mini-title"/>
                <Label fx:id="roleLabel" text="Rol" styleClass="muted"/>
            </VBox>
            <Button text="Cerrar sesión" maxWidth="Infinity" onAction="#logout" styleClass="danger-button"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="22" bottom="14" left="22"/>
            </padding>
            <Label text="Proyecto de prácticas en empresa · QUMI Papel" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="11–29 mayo" styleClass="date-pill"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane"/>
    </center>
</BorderPane>
