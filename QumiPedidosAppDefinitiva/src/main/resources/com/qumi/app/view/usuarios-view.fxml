<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.qumi.app.controller.UsuariosController">
    <padding>
        <Insets top="24" right="28" bottom="28" left="28"/>
    </padding>
    <top>
        <VBox spacing="12">
            <VBox spacing="5">
                <Label text="Gestión de usuarios" styleClass="page-title"/>
                <Label text="Pantalla de administración para crear usuarios y definir permisos por rol." styleClass="muted"/>
            </VBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Buscar usuario, nombre o rol" HBox.hgrow="ALWAYS" onAction="#refresh"/>
                <Button text="Buscar" onAction="#refresh" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <HBox spacing="18">
            <TableView fx:id="usuariosTable" HBox.hgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="55"/>
                    <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="220"/>
                    <TableColumn fx:id="usernameColumn" text="Usuario" prefWidth="160"/>
                    <TableColumn fx:id="roleColumn" text="Rol" prefWidth="150"/>
                    <TableColumn fx:id="activoColumn" text="Activo" prefWidth="90"/>
                </columns>
            </TableView>
            <VBox spacing="10" prefWidth="300" styleClass="form-card">
                <Label text="Ficha de usuario" styleClass="section-title"/>
                <TextField fx:id="nombreField" promptText="Nombre completo"/>
                <TextField fx:id="usernameField" promptText="Usuario"/>
                <PasswordField fx:id="passwordField" promptText="Contraseña"/>
                <ComboBox fx:id="roleCombo" promptText="Rol" maxWidth="Infinity"/>
                <CheckBox fx:id="activoCheck" text="Usuario activo"/>
                <HBox spacing="8">
                    <Button text="Guardar" onAction="#save" styleClass="primary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Limpiar" onAction="#clear" styleClass="secondary-button"/>
                </HBox>
                <Button text="Eliminar" onAction="#delete" styleClass="danger-button" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
