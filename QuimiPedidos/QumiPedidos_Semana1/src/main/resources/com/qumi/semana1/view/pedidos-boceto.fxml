<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox spacing="16.0">
            <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
            <Label text="Creación y consulta de pedidos - Boceto" styleClass="title" />
            <HBox spacing="16.0">
                <GridPane hgap="10.0" vgap="10.0" styleClass="card">
                    <Label text="Nuevo pedido" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox prefWidth="260.0" promptText="Seleccionar cliente" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox prefWidth="260.0" promptText="Seleccionar producto" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField promptText="Cantidad" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox prefWidth="260.0" promptText="Urgencia" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <ComboBox prefWidth="260.0" promptText="Estado inicial" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <TextArea prefRowCount="5" promptText="Observaciones" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <Button text="Añadir línea" styleClass="secondary-button" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    <Button text="Crear pedido" styleClass="primary-button" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                </GridPane>
                <TableView prefHeight="480.0" prefWidth="650.0">
                    <columns>
                        <TableColumn prefWidth="80.0" text="Pedido" />
                        <TableColumn prefWidth="160.0" text="Cliente" />
                        <TableColumn prefWidth="120.0" text="Fecha" />
                        <TableColumn prefWidth="120.0" text="Estado" />
                        <TableColumn prefWidth="110.0" text="Urgencia" />
                        <TableColumn prefWidth="90.0" text="Total" />
                    </columns>
                </TableView>
            </HBox>
        </VBox>
    </center>
</BorderPane>
