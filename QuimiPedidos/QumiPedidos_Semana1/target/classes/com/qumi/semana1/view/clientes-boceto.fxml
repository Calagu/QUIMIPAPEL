<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox spacing="16.0">
            <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
            <Label text="Gestión de clientes - Boceto" styleClass="title" />
            <HBox spacing="12.0">
                <TextField prefWidth="360.0" promptText="Buscar cliente por nombre, teléfono o localidad" />
                <Button text="Buscar" styleClass="secondary-button" />
                <Button text="Nuevo cliente" styleClass="primary-button" />
            </HBox>
            <HBox spacing="16.0">
                <TableView prefHeight="420.0" prefWidth="600.0">
                    <columns>
                        <TableColumn prefWidth="180.0" text="Nombre" />
                        <TableColumn prefWidth="120.0" text="Teléfono" />
                        <TableColumn prefWidth="200.0" text="Dirección" />
                        <TableColumn prefWidth="100.0" text="Localidad" />
                    </columns>
                </TableView>
                <GridPane hgap="10.0" vgap="10.0" styleClass="card">
                    <Label text="Formulario" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField promptText="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField promptText="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField promptText="Email" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField promptText="Dirección" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField promptText="Localidad" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <TextArea prefRowCount="4" promptText="Observaciones" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <HBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="7">
                        <Button text="Guardar" styleClass="primary-button" />
                        <Button text="Limpiar" styleClass="secondary-button" />
                    </HBox>
                </GridPane>
            </HBox>
        </VBox>
    </center>
</BorderPane>
