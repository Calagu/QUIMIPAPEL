<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <VBox spacing="16.0">
            <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
            <Label text="Gestión de productos - Boceto" styleClass="title" />
            <HBox spacing="12.0">
                <TextField prefWidth="360.0" promptText="Buscar producto por nombre o categoría" />
                <Button text="Buscar" styleClass="secondary-button" />
                <Button text="Nuevo producto" styleClass="primary-button" />
            </HBox>
            <HBox spacing="16.0">
                <TableView prefHeight="420.0" prefWidth="630.0">
                    <columns>
                        <TableColumn prefWidth="180.0" text="Producto" />
                        <TableColumn prefWidth="120.0" text="Categoría" />
                        <TableColumn prefWidth="80.0" text="Precio" />
                        <TableColumn prefWidth="80.0" text="Stock" />
                        <TableColumn prefWidth="130.0" text="Estado stock" />
                    </columns>
                </TableView>
                <GridPane hgap="10.0" vgap="10.0" styleClass="card">
                    <Label text="Formulario" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField promptText="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField promptText="Categoría" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField promptText="Precio" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField promptText="Stock" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField promptText="Stock mínimo" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <HBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="6">
                        <Button text="Guardar" styleClass="primary-button" />
                        <Button text="Limpiar" styleClass="secondary-button" />
                    </HBox>
                </GridPane>
            </HBox>
        </VBox>
    </center>
</BorderPane>
