<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <left>
        <VBox prefWidth="210.0" spacing="8.0" styleClass="sidebar">
            <Label text="QUMI PAPEL" styleClass="sidebar-title" />
            <Button text="Inicio" prefWidth="170.0" styleClass="menu-button" />
            <Button text="Clientes" prefWidth="170.0" styleClass="menu-button" />
            <Button text="Productos" prefWidth="170.0" styleClass="menu-button" />
            <Button text="Pedidos" prefWidth="170.0" styleClass="menu-button" />
            <Button text="Reparto" prefWidth="170.0" styleClass="menu-button" />
            <Button text="Usuarios" prefWidth="170.0" styleClass="menu-button" />
        </VBox>
    </left>
    <center>
        <VBox spacing="18.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Panel principal" styleClass="title" />
                <Label text="Boceto Semana 1" styleClass="subtitle" />
            </HBox>
            <GridPane hgap="16.0" vgap="16.0">
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" prefWidth="180.0" styleClass="card">
                    <Label text="12" styleClass="title" />
                    <Label text="Pedidos pendientes" styleClass="subtitle" />
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="180.0" styleClass="card">
                    <Label text="4" styleClass="title" />
                    <Label text="En reparto" styleClass="subtitle" />
                </VBox>
                <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" prefWidth="180.0" styleClass="card">
                    <Label text="3" styleClass="title" />
                    <Label text="Urgentes" styleClass="subtitle" />
                </VBox>
                <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="180.0" styleClass="card">
                    <Label text="5" styleClass="title" />
                    <Label text="Bajo stock" styleClass="subtitle" />
                </VBox>
            </GridPane>
            <TableView prefHeight="330.0">
                <columns>
                    <TableColumn prefWidth="90.0" text="Pedido" />
                    <TableColumn prefWidth="190.0" text="Cliente" />
                    <TableColumn prefWidth="120.0" text="Estado" />
                    <TableColumn prefWidth="120.0" text="Urgencia" />
                    <TableColumn prefWidth="160.0" text="Repartidor" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
